# ── Variables d'environnement ─────────────────────────────────────
# Copiez ce fichier en .env et adaptez les valeurs.
# ⚠️  Ne jamais committer le fichier .env dans Git !

# Environnement de l'application : development | staging | production
NODE_ENV=development

# Numéro de build (généré automatiquement par GitHub Actions en prod)
BUILD_NUMBER=local

# URL de base du site (utilisée dans les workflows de déploiement)
SITE_URL=http://localhost:5500
